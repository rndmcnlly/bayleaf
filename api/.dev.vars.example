# Copy this file to .dev.vars and fill in the values for local development
# DO NOT commit .dev.vars to version control!

OPENROUTER_PROVISIONING_KEY=sk-or-v1-your-provisioning-key-here
# OIDC credentials from your provider (CILogon, Google, etc.)
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
CAMPUS_POOL_KEY=sk-or-v1-your-campus-pool-key-here
DAYTONA_API_KEY=dtn_your-daytona-api-key-here